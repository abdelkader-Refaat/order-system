APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
# Arabic API messages: APP_LOCALE=ar (see lang/ar/messages.php)
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# rabbitmq = real broker (requires RabbitMQ running on RABBITMQ_HOST:5672)
# sync = process jobs immediately in the same request (no broker — OK for quick API testing)
QUEUE_CONNECTION=rabbitmq

# Full local stack: composer dev (starts RabbitMQ, then serve + orders:consume + vite + pail).
# Broker only: composer rabbitmq:up   |   Diagnose: php artisan orders:doctor
# docker-compose.yml sets ORDERS_SKIP_QUEUE_PUBLISH=false on app/queue-worker (overrides .env) so Docker API always publishes.

# RabbitMQ — IMPORTANT host:
# • PHP on your machine (Herd, `php artisan serve`, `php artisan orders:consume` in Terminal):
#     RABBITMQ_HOST=127.0.0.1   (broker must expose 5672 on localhost, e.g. docker compose up rabbitmq)
# • Do NOT set RABBITMQ_HOST=rabbitmq on the host — that name only exists inside Docker’s network.
# • `docker-compose.yml` sets RABBITMQ_HOST=rabbitmq for app/queue-worker containers (overrides .env there).
#
# If "Connection refused" on 5672: start the broker (docker compose up -d rabbitmq). If "getaddrinfo for rabbitmq failed": use 127.0.0.1 on the host.
# Diagnose: php artisan orders:check-broker (must succeed for API publish to work).
# After changing .env: php artisan optimize:clear (stale config cache breaks HTTP vs CLI).
# ORDERS_PUBLISH_FALLBACK_CLI=true (default): if FPM AMQP fails, republish via `php artisan orders:publish`. Ignored for `php artisan serve` (SAPI cli-server).
# ORDERS_LOCAL_MARK_PROCESSED_WITHOUT_BROKER=true (default): APP_ENV=local only — mark order processed when publish fails or skip_publish (no Docker needed). false to test real RabbitMQ.
# Real RabbitMQ: ORDERS_SKIP_QUEUE_PUBLISH=false, ORDERS_LOCAL_MARK_PROCESSED_WITHOUT_BROKER=false, start broker (composer rabbitmq:up), run orders:consume.
# ORDERS_SKIP_QUEUE_PUBLISH=true skips publish when testing API without RabbitMQ.
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=orders_queue

# Skip AMQP entirely (no TCP to the broker).
ORDERS_SKIP_QUEUE_PUBLISH=false
# If false, broker errors return 500. If true, publish failures are logged; API still succeeds (order may stay pending).
ORDERS_GRACEFUL_QUEUE_FAILURE=false

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
